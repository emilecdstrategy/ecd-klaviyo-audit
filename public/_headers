# Vite content-hashes everything under /assets/, so these files never change
# once published -- safe to cache immutably. Everything else (index.html, the
# unhashed favicons/images in public/) intentionally has NO rule here: Netlify's
# default (max-age=0, must-revalidate + ETag) is the correct behavior for files
# whose names don't change with their content, and Netlify applies ALL matching
# _headers rules to a path, so an overlapping /* rule would emit duplicate
# Cache-Control headers.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
